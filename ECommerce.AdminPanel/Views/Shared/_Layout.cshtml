<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
</head>
<body>
    <div class="container">
        <main role="main" class="pb-3">@RenderBody()</main>
    </div>
    <footer class="border-t mt-8 py-6 text-center text-sm text-muted">
        &copy; 2026 Admin Panel. All rights reserved.
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
