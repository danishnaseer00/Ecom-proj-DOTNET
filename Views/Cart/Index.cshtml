@model CartViewModel
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="max-w-4xl mx-auto px-8 py-8">
    <h1 class="text-2xl sm:text-3xl font-bold mb-6">Shopping Cart</h1>

    @if (!Model.Items.Any())
    {
        <div class="text-center py-16">
            <div class="text-gray-300 text-6xl mb-4"><i class="fas fa-shopping-cart"></i></div>
            <h3 class="text-xl text-gray-500">Your cart is empty</h3>
            <p class="text-gray-400">Browse our products and add items to your cart.</p>
            <a href="/" class="btn btn-primary mt-4">Start Shopping</a>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var item in Model.Items)
            {
                <div class="card border rounded-lg p-3 sm:p-4 shadow-sm">
                    <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4">
                        <div class="flex items-center gap-3 sm:flex-none">
                            <div class="w-14 h-14 sm:w-20 sm:h-20 bg-gray-100 rounded overflow-hidden flex-shrink-0 flex items-center justify-center">
                                <img src="@(item.ImageUrl ?? "/images/placeholder.svg")" class="max-w-full max-h-full object-contain" alt="@item.ProductName" />
                            </div>
                            <div class="sm:hidden">
                                <h4 class="font-semibold text-sm">@item.ProductName</h4>
                                <p class="text-gray-500 text-xs">$@item.UnitPrice.ToString("F2")</p>
                            </div>
                        </div>
                        <div class="hidden sm:block sm:flex-1">
                            <h4 class="font-semibold text-base">@item.ProductName</h4>
                            <p class="text-gray-500 text-sm">$@item.UnitPrice.ToString("F2")</p>
                        </div>
                        <div class="flex items-center justify-between sm:justify-end gap-2 sm:gap-4">
                            <form asp-action="UpdateQuantity" method="post" class="flex items-center gap-1 sm:gap-2">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <input type="number" name="quantity" value="@item.Quantity" min="0" class="form-control w-12 sm:w-16" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary text-xs">Update</button>
                            </form>
                            <p class="font-bold text-sm sm:text-base w-16 sm:w-24 text-right">$@item.Subtotal.ToString("F2")</p>
                            <form asp-action="Remove" method="post">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="btn btn-sm btn-danger text-xs">Remove</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="text-right mt-8">
            <p class="text-2xl font-bold">Total: $@Model.Total.ToString("F2")</p>
            <a href="/checkout" class="btn btn-primary btn-lg mt-4 transition-all duration-200 active:scale-95">Proceed to Checkout</a>
        </div>
    }
</div>