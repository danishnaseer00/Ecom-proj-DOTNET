@model ProductListViewModel
@{
    ViewData["Title"] = "Shop";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8">
    <h1 class="text-2xl sm:text-3xl font-bold mb-4 sm:mb-6">Shop All Products</h1>

    <div class="flex flex-col lg:flex-row gap-4 sm:gap-6">
        <!-- Sidebar Categories - Left Panel -->
        <aside class="w-full lg:w-40 flex-shrink-0">
            <div class="card border rounded-lg p-3 sm:p-4 shadow-sm sticky top-20 lg:static">
                <h3 class="text-xs sm:text-sm font-semibold uppercase tracking-wide mb-3" style="color: #2a2a3d;">Categories</h3>
                <ul class="space-y-2">
                    <li>
                        <a href="/home/shop" class="text-xs sm:text-sm font-medium transition-colors duration-200 @(Model.CategoryId == null ? "font-semibold" : "")" style="color: @(Model.CategoryId == null ? "#2a2a3d" : "#6c757d");">All Products</a>
                    </li>
                    @foreach (var cat in Model.Categories)
                    {
                        <li>
                            <a href="/home/shop?categoryId=@cat.Id" class="text-xs sm:text-sm font-medium transition-colors duration-200 @(Model.CategoryId == cat.Id ? "font-semibold" : "")" style="color: @(Model.CategoryId == cat.Id ? "#2a2a3d" : "#6c757d");">
                                @cat.Name
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </aside>

        <!-- Main Content - Right Section -->
        <div class="flex-1">
            <!-- Search Bar -->
            <div class="mb-5 sm:mb-6">
                <form action="/home/shop" method="get" class="flex items-center gap-2">
                    <input type="text" name="search" class="form-control flex-1 text-xs sm:text-sm placeholder-gray-400" placeholder="Search products..." value="@Model.SearchTerm" />
                    <button type="submit" class="btn btn-primary text-xs sm:text-sm py-2 px-3 sm:px-4 whitespace-nowrap">
                        <i class="fas fa-search"></i><span class="hidden sm:inline ml-1">Search</span>
                    </button>
                </form>
            </div>

            <!-- Results Counter -->
            @if (Model.Products.Any())
            {
                <p class="text-xs sm:text-sm text-gray-500 mb-4">
                    @Model.Products.Count() product@(Model.Products.Count() != 1 ? "s" : "") found
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <span>for "<strong>@Model.SearchTerm</strong>"</span>
                    }
                </p>
            }

            <!-- Product Grid -->
            @if (Model.Products.Any())
            {
                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2 sm:gap-3">
                    @foreach (var product in Model.Products)
                    {
                        <div class="card border rounded-lg overflow-hidden shadow-sm hover:shadow-lg transition-all duration-200 hover:-translate-y-1 flex flex-col">
                            <a href="/home/details/@product.Id" class="overflow-hidden">
                                <div class="aspect-w-1 aspect-h-1 bg-gray-100 h-32 sm:h-36 overflow-hidden">
                                    <img src="@(product.ImageUrl ?? "/images/placeholder.svg")" alt="@product.Name" loading="lazy" class="w-full h-full object-cover transition-transform duration-300 hover:scale-105" />
                                </div>
                            </a>
                            <div class="p-2 sm:p-3 flex flex-col flex-1 space-y-1">
                                <p class="text-xs text-gray-500 uppercase tracking-wide line-clamp-1">@product.CategoryName</p>
                                <a href="/home/details/@product.Id">
                                    <h3 class="text-xs sm:text-sm font-medium line-clamp-1 hover:text-brand-gray-500 transition-colors">@product.Name</h3>
                                </a>
                                <div class="flex items-center justify-between mt-auto pt-1.5">
                                    <span class="text-xs font-medium text-brand-gray-500">$@product.Price.ToString("F2")</span>
                                    <div class="flex items-center gap-1 sm:gap-2">
                                        <a href="/home/details/@product.Id" class="btn btn-sm btn-outline-secondary text-xs py-1 px-1 sm:px-1.5 transition-all duration-200 active:scale-95">View</a>
                                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="inline">
                                            <input type="hidden" name="productId" value="@product.Id" />
                                            <input type="hidden" name="quantity" value="1" />
                                            <button type="submit" class="btn btn-sm btn-primary text-xs py-1 px-1 sm:px-1.5 transition-all duration-200 active:scale-95">Add</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-8 sm:py-16">
                    <div class="text-gray-300 text-4xl sm:text-6xl mb-3 sm:mb-4"><i class="fas fa-box-open"></i></div>
                    <h3 class="text-lg sm:text-xl text-gray-500 font-medium">No products found</h3>
                    <p class="text-xs sm:text-sm text-gray-400 mt-2">@if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <span>No results for "<strong>@Model.SearchTerm</strong>"</span>
                    }
                    else
                    {
                        <span>Try adjusting your search or browse categories.</span>
                    }</p>
                </div>
            }
        </div>
    </div>
</div>
