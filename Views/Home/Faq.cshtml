@{
    ViewData["Title"] = "FAQ";
}

<div class="max-w-3xl mx-auto px-8 py-12">
    <h1 class="text-3xl font-bold mb-8">Frequently Asked Questions</h1>

    <div class="max-w-2xl space-y-6">
        <div class="card border rounded-lg p-6">
            <h3 class="text-lg font-semibold mb-2">How do I place an order?</h3>
            <p class="text-sm text-gray-500 leading-relaxed">Simply browse our products, add items to your cart, and proceed to checkout. Enter your shipping details and complete payment to confirm your order.</p>
        </div>
        <div class="card border rounded-lg p-6">
            <h3 class="text-lg font-semibold mb-2">What payment methods do you accept?</h3>
            <p class="text-sm text-gray-500 leading-relaxed">We accept all major credit and debit cards via Stripe. Your payment information is securely processed.</p>
        </div>
        <div class="card border rounded-lg p-6">
            <h3 class="text-lg font-semibold mb-2">How long does delivery take?</h3>
            <p class="text-sm text-gray-500 leading-relaxed">Delivery usually takes 3–5 business days within Pakistan. You will receive a confirmation email once your order is shipped.</p>
        </div>
        <div class="card border rounded-lg p-6">
            <h3 class="text-lg font-semibold mb-2">Can I cancel or return my order?</h3>
            <p class="text-sm text-gray-500 leading-relaxed">Orders can be cancelled within 24 hours of placement. Please contact our support team for return requests.</p>
        </div>
        <div class="card border rounded-lg p-6">
            <h3 class="text-lg font-semibold mb-2">Is my personal information secure?</h3>
            <p class="text-sm text-gray-500 leading-relaxed">Yes, we use industry-standard encryption to protect your data. We never share your personal information with third parties.</p>
        </div>
    </div>
</div>
