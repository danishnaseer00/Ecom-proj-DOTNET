@model ProductViewModel
@{
    ViewData["Title"] = Model.Name;
    var reviews = ViewBag.Reviews as List<ReviewViewModel> ?? new();
    var avgRating = Model.AverageRating;
}

<div class="max-w-7xl mx-auto px-4 sm:px-8 py-8">
    <div class="grid md:grid-cols-2 gap-6 sm:gap-8">
        <div class="bg-gray-100 rounded-lg overflow-hidden">
            <img src="@(Model.ImageUrl ?? "/images/placeholder.svg")" class="w-full h-64 sm:h-96 object-cover" alt="@Model.Name" />
        </div>
        <div>
            <p class="text-xs sm:text-sm text-gray-500 uppercase tracking-wide">@Model.CategoryName</p>
            <h1 class="text-2xl sm:text-3xl font-bold mt-2">@Model.Name</h1>
            <div class="flex items-center gap-2 mt-2">
                <div class="flex items-center gap-0.5">
                    @for (var i = 1; i <= 5; i++)
                    {
                        <i class="fas fa-star text-sm @(i <= Math.Round(avgRating) ? "text-warning" : "text-gray-300")"></i>
                    }
                </div>
                <span class="text-sm text-gray-500">(@Model.ReviewCount reviews)</span>
            </div>
            <p class="text-2xl sm:text-3xl font-bold text-gray-900 mt-4">$@Model.Price.ToString("F2")</p>
            <p class="text-gray-500 mt-4 leading-relaxed text-sm sm:text-base">@Model.Description</p>
            <div class="mt-4">
                @if (Model.StockQuantity > 0)
                {
                    <span class="badge bg-success">In Stock (@Model.StockQuantity available)</span>
                }
                else
                {
                    <span class="badge bg-danger">Out of Stock</span>
                }
            </div>
            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mt-6">
                <input type="hidden" name="productId" value="@Model.Id" />
                <div class="flex items-center gap-4">
                    <input type="number" name="quantity" value="1" min="1" max="@(Model.StockQuantity > 0 ? Model.StockQuantity : 1)" class="form-control w-20" @(Model.StockQuantity == 0 ? "disabled" : "") />
                    <button type="submit" class="btn btn-primary px-6 sm:px-8 transition-all duration-200 active:scale-95" @(Model.StockQuantity == 0 ? "disabled" : "")>Add to Cart</button>
                </div>
            </form>
            <a href="/" class="btn btn-outline-secondary mt-4 text-sm">&larr; Continue Shopping</a>
        </div>
    </div>

    <section class="mt-12 sm:mt-16">
        <h2 class="text-xl sm:text-2xl font-bold mb-6">Customer Reviews</h2>

        @if (TempData["ReviewSuccess"] != null)
        {
            <div class="bg-success text-white p-3 rounded mb-4 text-sm">@TempData["ReviewSuccess"]</div>
        }

        <div class="card border rounded-lg p-4 sm:p-6 shadow-sm mb-8">
            <h3 class="font-semibold mb-4">Write a Review</h3>
            <form asp-action="AddReview" method="post">
                <input type="hidden" name="ProductId" value="@Model.Id" />
                <div class="mb-4">
                    <label class="form-label">Rating</label>
                    <div class="flex items-center gap-1" id="star-rating">
                        @for (var i = 1; i <= 5; i++)
                        {
                            <button type="button" class="star-btn text-2xl text-gray-300" data-value="@i" style="background:none;border:none;cursor:pointer;padding:0;line-height:1;">
                                <i class="fas fa-star"></i>
                            </button>
                        }
                        <input type="hidden" name="Rating" id="rating-value" value="5" />
                    </div>
                </div>
                <div class="mb-4">
                    <label class="form-label">Comment</label>
                    <textarea name="Comment" class="form-control" rows="3" placeholder="Share your thoughts..." maxlength="1000"></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Submit Review</button>
            </form>
        </div>

        @if (reviews.Any())
        {
            <div class="space-y-4">
                @foreach (var review in reviews)
                {
                    <div class="card border rounded-lg p-4 sm:p-6 shadow-sm">
                        <div class="flex items-center justify-between mb-2">
                            <div class="flex items-center gap-2">
                                <div class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-sm font-semibold text-gray-600">
                                    @review.UserName[..1].ToUpper()
                                </div>
                                <span class="font-semibold text-sm">@review.UserName</span>
                            </div>
                            <span class="text-xs text-gray-400">@review.CreatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="flex items-center gap-0.5 mb-2">
                            @for (var i = 1; i <= 5; i++)
                            {
                                <i class="fas fa-star text-xs @(i <= review.Rating ? "text-warning" : "text-gray-300")"></i>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(review.Comment))
                        {
                            <p class="text-sm text-gray-600 leading-relaxed">@review.Comment</p>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-12 text-gray-400">
                <div class="text-4xl mb-2"><i class="far fa-comment-dots"></i></div>
                <p class="text-sm">No reviews yet. Be the first to review!</p>
            </div>
        }
    </section>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.star-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                var val = parseInt(this.dataset.value);
                document.getElementById('rating-value').value = val;
                document.querySelectorAll('.star-btn').forEach(function(s, i) {
                    s.style.color = i < val ? '#ffc107' : '#ced4da';
                });
            });
        });
    </script>
}
