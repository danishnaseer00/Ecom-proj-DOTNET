@model ProductListViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero bg-gray-50 py-6 sm:py-8 text-center">
    <div class="max-w-4xl mx-auto px-4">
        <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 mb-2 sm:mb-4">Discover Quality Products</h1>
        <p class="text-sm sm:text-base text-gray-500 mb-4 sm:mb-6">Shop the latest trends with confidence and style.</p>
        <form asp-action="Index" method="get" class="flex justify-center gap-2 max-w-sm mx-auto">
            <input type="text" name="search" class="form-control text-sm" placeholder="Search..." value="@Context.Request.Query["search"]" />
            <button type="submit" class="btn btn-primary text-sm">Search</button>
        </form>
    </div>
</section>

@{
    var newArrivals = ViewBag.NewArrivals as List<ProductViewModel> ?? new();
    var bestSellers = ViewBag.BestSellers as List<ProductViewModel> ?? new();
}

<section class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    <h2 class="text-xl sm:text-2xl font-bold mb-4 sm:mb-6">All Products</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2 sm:gap-3">
        @foreach (var product in Model.Products)
        {
            <div class="card border rounded-lg overflow-hidden shadow-sm hover:shadow-lg transition-all duration-200 hover:-translate-y-1 flex flex-col">
                <a href="/home/details/@product.Id">
                    <div class="aspect-w-1 aspect-h-1 bg-gray-100 h-32 sm:h-36">
                        <img src="@(product.ImageUrl ?? "/images/placeholder.svg")" alt="@product.Name" loading="lazy" />
                    </div>
                </a>
                <div class="p-2 sm:p-3 flex flex-col flex-1 space-y-1">
                    <p class="text-xs text-gray-500 uppercase tracking-wide line-clamp-1">@product.CategoryName</p>
                    <a href="/home/details/@product.Id">
                        <h3 class="text-xs sm:text-sm font-medium line-clamp-1">@product.Name</h3>
                    </a>
                    <div class="flex items-center justify-between mt-auto pt-1">
                        <span class="text-xs text-brand-gray-500">$@product.Price.ToString("F2")</span>
                        <div class="flex items-center gap-1">
                            <a href="/home/details/@product.Id" class="btn btn-sm btn-outline-secondary text-xs py-1 px-1.5 transition-all duration-200 active:scale-95">View</a>
                            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                <input type="hidden" name="productId" value="@product.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-sm btn-primary text-xs py-1 px-1.5 transition-all duration-200 active:scale-95">Add</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Products.Any())
    {
        <div class="text-center py-8 sm:py-16">
            <div class="text-gray-300 text-4xl sm:text-6xl mb-3 sm:mb-4"><i class="fas fa-box-open"></i></div>
            <h3 class="text-lg sm:text-xl text-gray-500">No products found</h3>
            <p class="text-xs sm:text-sm text-gray-400">Try adjusting your search or browse categories.</p>
        </div>
    }
</section>

@if (newArrivals.Any())
{
    <section class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
        <div class="flex items-center justify-between mb-4 sm:mb-6">
            <h2 class="text-xl sm:text-2xl font-bold">New Arrivals</h2>
            <a href="/home/shop" class="text-xs sm:text-sm font-medium" style="color: #2a2a3d;">View All &rarr;</a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2 sm:gap-3">
            @foreach (var product in newArrivals)
            {
                <a href="/home/details/@product.Id" class="card border rounded-lg overflow-hidden shadow-sm hover:shadow-lg transition-all duration-200 hover:-translate-y-1 flex flex-col">
                    <div class="aspect-w-1 aspect-h-1 bg-gray-100 h-32 sm:h-36">
                        <img src="@(product.ImageUrl ?? "/images/placeholder.svg")" alt="@product.Name" loading="lazy" />
                    </div>
                    <div class="p-2 sm:p-3 flex flex-col flex-1 space-y-1">
                        <p class="text-xs text-gray-500 uppercase tracking-wide line-clamp-1">@product.CategoryName</p>
                        <h3 class="text-xs sm:text-sm font-medium line-clamp-1">@product.Name</h3>
                        <span class="text-xs text-brand-gray-500 mt-auto pt-1">$@product.Price.ToString("F2")</span>
                    </div>
                </a>
            }
        </div>
    </section>
}

@if (bestSellers.Any())
{
    <section class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12 bg-gray-50">
        <div class="flex items-center justify-between mb-4 sm:mb-6">
            <h2 class="text-xl sm:text-2xl font-bold">Best Sellers</h2>
            <a href="/home/shop" class="text-xs sm:text-sm font-medium" style="color: #2a2a3d;">View All &rarr;</a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2 sm:gap-3">
            @foreach (var product in bestSellers)
            {
                <a href="/home/details/@product.Id" class="card border rounded-lg overflow-hidden shadow-sm hover:shadow-lg transition-all duration-200 hover:-translate-y-1 flex flex-col">
                    <div class="aspect-w-1 aspect-h-1 bg-gray-100 h-32 sm:h-36">
                        <img src="@(product.ImageUrl ?? "/images/placeholder.svg")" alt="@product.Name" loading="lazy" />
                    </div>
                    <div class="p-2 sm:p-3 flex flex-col flex-1 space-y-1">
                        <p class="text-xs text-gray-500 uppercase tracking-wide line-clamp-1">@product.CategoryName</p>
                        <h3 class="text-xs sm:text-sm font-medium line-clamp-1">@product.Name</h3>
                        <span class="text-xs text-brand-gray-500 mt-auto pt-1">$@product.Price.ToString("F2")</span>
                    </div>
                </a>
            }
        </div>
    </section>
}
