@model ProductListViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero bg-gray-50 py-6 sm:py-8 text-center">
    <div class="max-w-4xl mx-auto px-4">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-2 sm:mb-4">Discover Quality Products</h1>
        <p class="text-sm sm:text-base text-gray-500 mb-4 sm:mb-6">Shop the latest trends with confidence and style.</p>
        <form asp-action="Index" method="get" class="flex justify-center gap-2 max-w-sm mx-auto">
            <input type="text" name="search" class="form-control text-sm" placeholder="Search..." value="@Context.Request.Query["search"]" />
            <button type="submit" class="btn btn-primary text-sm">Search</button>
        </form>
    </div>
</section>

@{
    var newArrivals = ViewBag.NewArrivals as List<ProductViewModel> ?? new();
    var bestSellers = ViewBag.BestSellers as List<ProductViewModel> ?? new();
}

<section class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
    <h2 class="text-xl sm:text-2xl font-bold mb-4 sm:mb-6">All Products</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2 sm:gap-3">
        @foreach (var product in Model.Products)
        {
            <div class="card border rounded-lg overflow-hidden shadow-sm hover:shadow-lg transition-all duration-200 hover:-translate-y-1 flex flex-col">
                <a href="/home/details/@product.Id">
                    <div class="aspect-w-1 aspect-h-1 bg-gray-100 h-32 sm:h-36">
                        <img src="@(product.ImageUrl ?? "/images/placeholder.svg")" alt="@product.Name" loading="lazy" />
                    </div>
                </a>
                <div class="p-2 sm:p-3 flex flex-col flex-1 space-y-1">
                    <p class="text-xs text-gray-500 uppercase tracking-wide line-clamp-1">@product.CategoryName</p>
                    <a href="/home/details/@product.Id">
                        <h3 class="text-xs sm:text-sm font-medium line-clamp-1">@product.Name</h3>
                    </a>
                    <div class="flex items-center justify-between mt-auto pt-1">
                        <span class="text-xs text-brand-gray-500">$@product.Price.ToString("F2")</span>
                        <div class="flex items-center gap-1 sm:gap-2">
                            <a href="/home/details/@product.Id" class="btn btn-sm btn-outline-secondary text-xs py-1 px-1 sm:px-1.5 transition-all duration-200 active:scale-95">View</a>
                            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                <input type="hidden" name="productId" value="@product.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <button type="submit" class="btn btn-sm btn-primary text-xs py-1 px-1 sm:px-1.5 transition-all duration-200 active:scale-95">Add</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Products.Any())
    {
        <div class="text-center py-8 sm:py-16">
            <div class="text-gray-300 text-4xl sm:text-6xl mb-3 sm:mb-4"><i class="fas fa-box-open"></i></div>
            <h3 class="text-lg sm:text-xl text-gray-500">No products found</h3>
            <p class="text-xs sm:text-sm text-gray-400">Try adjusting your search or browse categories.</p>
        </div>
    }
</section>

@if (newArrivals.Any())
{
    <section class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
        <div class="flex items-center justify-between mb-4 sm:mb-6">
            <h2 class="text-xl sm:text-2xl font-bold">New Arrivals</h2>
            <a href="/home/shop" class="text-xs sm:text-sm font-medium" style="color: #2a2a3d;">View All &rarr;</a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2 sm:gap-3">
            @foreach (var product in newArrivals)
            {
                <a href="/home/details/@product.Id" class="card border rounded-lg overflow-hidden shadow-sm hover:shadow-lg transition-all duration-200 hover:-translate-y-1 flex flex-col">
                    <div class="aspect-w-1 aspect-h-1 bg-gray-100 h-32 sm:h-36">
                        <img src="@(product.ImageUrl ?? "/images/placeholder.svg")" alt="@product.Name" loading="lazy" />
                    </div>
                    <div class="p-2 sm:p-3 flex flex-col flex-1 space-y-1">
                        <p class="text-xs text-gray-500 uppercase tracking-wide line-clamp-1">@product.CategoryName</p>
                        <h3 class="text-xs sm:text-sm font-medium line-clamp-1">@product.Name</h3>
                        <span class="text-xs text-brand-gray-500 mt-auto pt-1">$@product.Price.ToString("F2")</span>
                    </div>
                </a>
            }
        </div>
    </section>
}

@if (bestSellers.Any())
{
    <section class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-12 bg-gray-50">
        <div class="flex items-center justify-between mb-4 sm:mb-6">
            <h2 class="text-xl sm:text-2xl font-bold">Best Sellers</h2>
            <a href="/home/shop" class="text-xs sm:text-sm font-medium" style="color: #2a2a3d;">View All &rarr;</a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2 sm:gap-3">
            @foreach (var product in bestSellers)
            {
                <a href="/home/details/@product.Id" class="card border rounded-lg overflow-hidden shadow-sm hover:shadow-lg transition-all duration-200 hover:-translate-y-1 flex flex-col">
                    <div class="aspect-w-1 aspect-h-1 bg-gray-100 h-32 sm:h-36">
                        <img src="@(product.ImageUrl ?? "/images/placeholder.svg")" alt="@product.Name" loading="lazy" />
                    </div>
                    <div class="p-2 sm:p-3 flex flex-col flex-1 space-y-1">
                        <p class="text-xs text-gray-500 uppercase tracking-wide line-clamp-1">@product.CategoryName</p>
                        <h3 class="text-xs sm:text-sm font-medium line-clamp-1">@product.Name</h3>
                        <span class="text-xs text-brand-gray-500 mt-auto pt-1">$@product.Price.ToString("F2")</span>
                    </div>
                </a>
            }
        </div>
    </section>
}

@{
    var recentReviews = ViewBag.RecentReviews as List<ReviewViewModel> ?? new();
}

<!-- Why Choose Us -->
<section class="py-12 sm:py-16" style="background: #f8f9fa;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <h2 class="text-2xl sm:text-3xl font-bold text-center mb-2">Why Choose Us</h2>
        <p class="text-sm sm:text-base text-gray-500 text-center mb-8 sm:mb-10 max-w-xl mx-auto">We're committed to delivering the best shopping experience possible.</p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6">
            <div class="text-center p-4 sm:p-6">
                <div class="w-12 h-12 sm:w-14 sm:h-14 flex items-center justify-center mx-auto mb-3 sm:mb-4">
                    <i class="fas fa-medal text-xl sm:text-2xl" style="color: #2a2a3d;"></i>
                </div>
                <h3 class="font-semibold text-sm sm:text-base mb-1">Premium Quality</h3>
                <p class="text-xs sm:text-sm text-gray-500">Curated products from trusted brands, rigorously tested for excellence.</p>
            </div>
            <div class="text-center p-4 sm:p-6">
                <div class="w-12 h-12 sm:w-14 sm:h-14 flex items-center justify-center mx-auto mb-3 sm:mb-4">
                    <i class="fas fa-truck text-xl sm:text-2xl" style="color: #2a2a3d;"></i>
                </div>
                <h3 class="font-semibold text-sm sm:text-base mb-1">Fast Delivery</h3>
                <p class="text-xs sm:text-sm text-gray-500">Free shipping on orders over $50. Delivered to your door in 2-4 days.</p>
            </div>
            <div class="text-center p-4 sm:p-6">
                <div class="w-12 h-12 sm:w-14 sm:h-14 flex items-center justify-center mx-auto mb-3 sm:mb-4">
                    <i class="fas fa-shield-alt text-xl sm:text-2xl" style="color: #2a2a3d;"></i>
                </div>
                <h3 class="font-semibold text-sm sm:text-base mb-1">Secure Checkout</h3>
                <p class="text-xs sm:text-sm text-gray-500">Your data is encrypted and protected with industry-standard security.</p>
            </div>
            <div class="text-center p-4 sm:p-6">
                <div class="w-12 h-12 sm:w-14 sm:h-14 flex items-center justify-center mx-auto mb-3 sm:mb-4">
                    <i class="fas fa-headset text-xl sm:text-2xl" style="color: #2a2a3d;"></i>
                </div>
                <h3 class="font-semibold text-sm sm:text-base mb-1">24/7 Support</h3>
                <p class="text-xs sm:text-sm text-gray-500">Our team is here around the clock to answer your questions.</p>
            </div>
        </div>
    </div>
</section>

<!-- Customer Reviews -->
@if (recentReviews.Any())
{
    <section class="py-12 sm:py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6">
            <h2 class="text-2xl sm:text-3xl font-bold text-center mb-2">What Our Customers Say</h2>
            <p class="text-sm sm:text-base text-gray-500 text-center mb-8 sm:mb-10 max-w-xl mx-auto">Real reviews from real customers.</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 sm:gap-6 auto-rows-fr">
                @foreach (var review in recentReviews)
                {
                    <div class="border rounded-xl p-4 sm:p-6 shadow-sm hover:shadow-md transition-shadow flex flex-col">
                        <div class="flex items-center gap-1 mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="fas fa-star text-xs @(i <= review.Rating ? "text-yellow-400" : "text-gray-200")"></i>
                            }
                        </div>
                        <p class="text-sm text-gray-600 mb-3 italic line-clamp-3">"@review.Comment"</p>
                        <div class="flex items-center gap-2 mt-auto">
                            <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold text-white shrink-0" style="background: #2a2a3d;">
                                @review.UserName.Substring(0, 1).ToUpper()
                            </div>
                            <div class="min-w-0">
                                <p class="text-sm font-medium truncate">@review.UserName</p>
                                <p class="text-xs text-gray-400">@review.CreatedAt.ToString("MMM dd, yyyy")</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}
