@{
    ViewData["Title"] = "Check Your Email";
    var confirmLink = TempData["ConfirmEmailLink"] as string;
}

<div class="max-w-md mx-auto px-8 py-16 text-center">
    <div class="text-6xl text-gray-300 mb-6"><i class="fas fa-envelope"></i></div>
    <h1 class="text-3xl font-bold mb-4">Check Your Email</h1>
    <p class="text-gray-500 mb-6">
        We sent a confirmation link to <strong>@TempData["ConfirmEmail"]</strong>. Click the link to activate your account.
    </p>
    @if (!string.IsNullOrEmpty(confirmLink))
    {
        <div class="bg-gray-100 rounded p-4 mb-6 text-left">
            <p class="text-xs font-semibold text-gray-500 uppercase mb-2">Confirmation Link</p>
            <a href="@confirmLink" class="text-sm font-medium break-all" style="color: #2a2a3d;">@confirmLink</a>
        </div>
    }
    <p class="text-sm text-gray-400">
        Didn't get it? Check your spam folder or <a href="/account/register" class="font-medium" style="color: #2a2a3d;">try again</a>.
    </p>
</div>
