@{
    ViewData["Title"] = "Login";
    var returnUrl = ViewBag.ReturnUrl as string;
    var unconfirmedEmail = ViewBag.UnconfirmedEmail as string;
}

<div class="max-w-md mx-auto px-8 py-16">
    <h1 class="text-3xl font-bold text-center mb-8">Login</h1>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert-toast">
            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <p class="mb-0">@err.ErrorMessage</p>
            }
        </div>
    }

    <form method="post" class="space-y-4">
        <input type="hidden" name="returnUrl" value="@returnUrl" />
        <div>
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" value="@unconfirmedEmail" required />
        </div>
        <div>
            <label class="form-label">Password</label>
            <div class="password-wrap">
                <input type="password" name="password" class="form-control" required />
                <button type="button" class="password-toggle" tabindex="-1"><i class="fas fa-eye"></i></button>
            </div>
        </div>
        <button type="submit" class="btn btn-primary w-full">Login</button>
    </form>

    @if (!string.IsNullOrEmpty(unconfirmedEmail))
    {
        <div class="text-center mt-4">
            <a href="/account/resendconfirmation?email=@Uri.EscapeDataString(unconfirmedEmail)" class="text-sm font-medium" style="color: #2a2a3d;">Resend confirmation email</a>
        </div>
    }

    <p class="text-center text-sm mt-4 text-gray-500">
        Don't have an account? <a href="/account/register?returnUrl=@(returnUrl ?? "")">Register</a>
    </p>
</div>
