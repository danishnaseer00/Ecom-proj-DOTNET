@{
    ViewData["Title"] = "Resend Confirmation";
    var email = Context.Request.Query["email"];
}

<div class="max-w-md mx-auto px-8 py-16">
    <h1 class="text-3xl font-bold text-center mb-8">Resend Confirmation</h1>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="bg-danger text-white p-3 rounded mb-4">
            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <p class="mb-0 text-sm">@err.ErrorMessage</p>
            }
        </div>
    }

    <form method="post" class="space-y-4">
        <div>
            <label class="form-label">Email</label>
            <input type="email" name="email" class="form-control" value="@email" required />
        </div>
        <button type="submit" class="btn btn-primary w-full">Resend Confirmation</button>
    </form>

    <p class="text-center text-sm mt-4 text-gray-500">
        <a href="/account/login">Back to Login</a>
    </p>
</div>
