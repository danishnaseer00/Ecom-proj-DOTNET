<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { margin: 0; background: #f8f9fa; font-family: 'Inter', sans-serif; min-height: 100vh; display: flex; }

        /* Sidebar */
        .admin-sidebar {
            width: 240px; background: #2a2a3d; flex-shrink: 0;
            display: flex; flex-direction: column; position: sticky; top: 0; height: 100vh;
            z-index: 1000; transition: transform 0.25s ease;
        }
        .admin-sidebar .brand {
            font-family: 'Playfair Display', serif; font-size: 1.25rem; font-weight: 700;
            color: #fff; padding: 1.25rem; display: block; text-decoration: none;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .admin-sidebar .brand:hover { color: #fff; }
        .admin-sidebar nav { padding: 0.75rem 0; flex: 1; overflow-y: auto; }
        .admin-sidebar nav a {
            display: flex; align-items: center; gap: 0.75rem;
            padding: 0.625rem 1.25rem; color: #d4d8dd; font-size: 0.875rem;
            text-decoration: none; transition: all 0.2s; font-weight: 500;
        }
        .admin-sidebar nav a:hover { background: rgba(255,255,255,0.08); color: #fff; }
        .admin-sidebar nav a i { width: 1.25rem; text-align: center; font-size: 1rem; }
        .sidebar-overlay { display: none; }

        /* Main area */
        .admin-main { flex: 1; display: flex; flex-direction: column; min-width: 0; max-width: 100%; }

        /* Top navbar */
        .admin-navbar {
            height: 64px; background: #fff; border-bottom: 1px solid #adb5bd;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 1.5rem; flex-shrink: 0; gap: 0.75rem;
        }
        .admin-navbar .left { display: flex; align-items: center; gap: 0.75rem; }
        .admin-navbar .page-title { font-family: 'Playfair Display', serif; font-size: 1.25rem; font-weight: 700; color: #2a2a3d; white-space: nowrap; }
        .admin-navbar .nav-actions { display: flex; align-items: center; gap: 0.75rem; }
        .admin-navbar .nav-actions a, .admin-navbar .nav-actions button {
            color: #6c757d; font-size: 0.875rem; font-weight: 500;
            background: none; border: none; cursor: pointer; text-decoration: none; padding: 0.5rem;
            border-radius: 6px; transition: all 0.2s; display: inline-flex; align-items: center; gap: 0.375rem;
        }
        .admin-navbar .nav-actions a:hover, .admin-navbar .nav-actions button:hover { color: #2a2a3d; background: #f1f3f5; }
        .hamburger {
            display: none; background: none; border: none; cursor: pointer;
            color: #2a2a3d; font-size: 1.25rem; padding: 0.25rem;
        }

        /* Content */
        .admin-content { flex: 1; padding: 1.5rem; overflow-y: auto; width: 100%; }
        .admin-footer {
            border-top: 1px solid #adb5bd; background: #fff;
            text-align: center; padding: 1rem; font-size: 0.8rem; color: #6c757d; flex-shrink: 0;
        }

        /* Cards */
        .admin-content .card {
            background: #fff; border: 1px solid #adb5bd; border-radius: 8px; margin-bottom: 1.25rem;
        }
        .admin-content .card-header {
            padding: 0.875rem 1.25rem; border-bottom: 1px solid #adb5bd;
            display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
        }
        .admin-content .card-header h3 { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700; color: #2a2a3d; margin: 0; }
        .admin-content .card-body { padding: 1.25rem; }
        .admin-content .card-body.p-0 { padding: 0; }

        /* Tables */
        .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
        .admin-content .table { width: 100%; border-collapse: collapse; font-size: 0.875rem; min-width: 600px; }
        .admin-content .table th {
            text-align: left; padding: 0.75rem 1.25rem; font-weight: 600;
            border-bottom: 2px solid #dee2e6; color: #495057; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap;
        }
        .admin-content .table td { padding: 0.75rem 1.25rem; border-bottom: 1px solid #dee2e6; }
        .admin-content .table-striped tbody tr:nth-child(odd) { background: #f8f9fa; }

        /* Dashboard stat boxes */
        .stat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }
        .admin-content .small-box {
            border-radius: 8px; padding: 1.25rem; color: #fff; position: relative; overflow: hidden;
        }
        .admin-content .small-box .inner h3 { font-family: 'Inter', sans-serif; font-size: 1.75rem; font-weight: 700; margin: 0; color: #fff; }
        .admin-content .small-box .inner p { font-size: 0.85rem; opacity: 0.9; margin: 0.25rem 0 0; }
        .admin-content .small-box .icon { position: absolute; top: 0.75rem; right: 0.75rem; font-size: 2.5rem; opacity: 0.2; }

        /* Forms */
        .form-group { margin-bottom: 1.25rem; }
        .form-group label { display: block; font-size: 0.875rem; font-weight: 600; color: #2a2a3d; margin-bottom: 0.375rem; }
        .form-group .form-control {
            width: 100%; padding: 0.625rem 0.75rem; font-size: 0.9rem; font-family: 'Inter', sans-serif;
            border: 1px solid #ced4da; border-radius: 8px; background: #fff; transition: border-color 0.2s, box-shadow 0.2s;
        }
        .form-group .form-control:focus { outline: none; border-color: #2a2a3d; box-shadow: 0 0 0 3px rgba(42,42,61,0.12); }
        .form-group textarea.form-control { resize: vertical; min-height: 100px; }
        .form-group select.form-control { appearance: auto; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
        .form-actions { display: flex; gap: 0.75rem; align-items: center; padding-top: 0.5rem; border-top: 1px solid #dee2e6; margin-top: 0.5rem; }
        .form-actions .btn { padding: 0.625rem 1.5rem; font-size: 0.9rem; }
        .mt-3 { margin-top: 0.75rem; }
        .mb-0 { margin-bottom: 0; }
        /* File input */
        .file-input-wrap { position: relative; }
        .file-input {
            position: absolute; inset: 0; opacity: 0; cursor: pointer; z-index: 2;
        }
        .file-input-label {
            display: flex; align-items: center; gap: 0.5rem;
            padding: 0.75rem 1rem; border: 2px dashed #ced4da; border-radius: 8px;
            color: #6c757d; font-size: 0.875rem; transition: all 0.2s; cursor: pointer;
        }
        .file-input-wrap:hover .file-input-label { border-color: #2a2a3d; color: #2a2a3d; background: #f8f9fa; }
        .file-hint { font-size: 0.75rem; color: #6c757d; margin-top: 0.375rem; }
        .current-image { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; padding: 0.5rem; background: #f8f9fa; border-radius: 8px; }
        .img-preview { display: none; margin-top: 0.5rem; padding: 0.5rem; background: #f8f9fa; border-radius: 8px; align-items: center; gap: 0.75rem; }
        .img-preview.show { display: flex; }
        .img-preview img { width: 64px; height: 64px; object-fit: cover; border-radius: 6px; }
        .img-preview span { font-size: 0.8rem; color: #495057; }
        .alert { padding: 0.875rem 1.25rem; border-radius: 8px; margin-bottom: 1.25rem; font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem; }
        .alert-success { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .alert-danger { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
        .current-image img { width: 64px; height: 64px; object-fit: cover; border-radius: 6px; }
        .current-image span { font-size: 0.8rem; color: #6c757d; }
        .btn-secondary { background: transparent; color: #6c757d; border-color: #adb5bd; }
        .btn-secondary:hover { background: #6c757d; color: #fff; border-color: #6c757d; }
        .btn-info { background: #17a2b8; color: #fff; border-color: #17a2b8; }
        .btn-info:hover { background: #138496; border-color: #117a8b; color: #fff; }
        .text-muted { color: #6c757d; }

        /* Mobile */
        @@media (min-width: 769px) {
            .admin-content .card { max-width: 720px; }
        }
        @@media (max-width: 768px) {
            .form-row { grid-template-columns: 1fr; gap: 0; }
            .admin-sidebar {
                position: fixed; left: 0; top: 0; height: 100vh; transform: translateX(-100%);
                box-shadow: 4px 0 24px rgba(0,0,0,0.15);
            }
            .admin-sidebar.open { transform: translateX(0); }
            .sidebar-overlay {
                display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4);
                z-index: 999;
            }
            .sidebar-overlay.show { display: block; }

            .hamburger { display: inline-flex; align-items: center; justify-content: center; }
            .admin-navbar { padding: 0 1rem; }
            .admin-navbar .page-title { font-size: 1rem; }
            .admin-navbar .nav-actions a span, .admin-navbar .nav-actions button span { display: none; }

            .admin-content { padding: 1rem; }
            .admin-content .card-header { padding: 0.75rem 1rem; }
            .admin-content .card-body { padding: 0.75rem 1rem; }
            .admin-content .table th, .admin-content .table td { padding: 0.5rem 0.75rem; }
            .form-group { margin-bottom: 1rem; }
            .form-actions { flex-direction: column; }
            .form-actions .btn { width: 100%; text-align: center; }

            .stat-grid { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
            .admin-content .small-box { padding: 1rem; }
            .admin-content .small-box .inner h3 { font-size: 1.25rem; }
            .admin-content .small-box .inner p { font-size: 0.75rem; }
            .admin-content .small-box .icon { font-size: 1.75rem; }
        }

        @@media (max-width: 480px) {
            .admin-content { padding: 0.75rem; }
            .stat-grid { grid-template-columns: 1fr; gap: 0.5rem; }
            .admin-content .card { margin-bottom: 0.75rem; }
            .admin-navbar { height: 56px; }
        }
    </style>
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <aside class="admin-sidebar" id="adminSidebar">
        <a href="/admin/dashboard" class="brand">Store Admin</a>
        <nav>
            <a href="/admin/dashboard"><i class="fas fa-tachometer-alt"></i>Dashboard</a>
            <a href="/admin/products"><i class="fas fa-box"></i>Products</a>
            <a href="/admin/categories"><i class="fas fa-tags"></i>Categories</a>
            <a href="/admin/orders"><i class="fas fa-shopping-cart"></i>Orders</a>
            <a href="/admin/customers"><i class="fas fa-users"></i>Customers</a>
        </nav>
    </aside>

    <div class="admin-main">
        <nav class="admin-navbar">
            <div class="left">
                <button class="hamburger" id="hamburgerBtn" aria-label="Toggle sidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="page-title">@ViewData["Title"]</div>
            </div>
            <div class="nav-actions">
                <a href="/"><i class="fas fa-external-link-alt"></i><span>View Store</span></a>
                <form method="post" asp-area="Identity" asp-page="/Account/Logout" style="display:inline">
                    <button type="submit"><i class="fas fa-sign-out-alt"></i><span>Logout</span></button>
                </form>
            </div>
        </nav>

        <div class="admin-content">
            @if (TempData["Success"] is string success)
            {
                <div class="alert alert-success"><i class="fas fa-check-circle"></i> @success</div>
            }
            @if (TempData["Error"] is string error)
            {
                <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> @error</div>
            }
            @RenderBody()
        </div>

        <footer class="admin-footer">
            &copy; 2026 E-Commerce Store. All rights reserved.
        </footer>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var btn = document.getElementById('hamburgerBtn');
            var sidebar = document.getElementById('adminSidebar');
            var overlay = document.getElementById('sidebarOverlay');
            function toggle() {
                sidebar.classList.toggle('open');
                overlay.classList.toggle('show');
            }
            btn.addEventListener('click', toggle);
            overlay.addEventListener('click', toggle);
        });
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
